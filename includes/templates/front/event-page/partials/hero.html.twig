{% set title = hero.title|default('') %}
{% set type_label = hero.type_label|default('') %}
{% set status_label = hero.status_label|default('') %}
{% set status = hero.status|default('') %}
{% set is_active = hero.is_active|default(false) %}
{% set cover_url = hero.cover_url|default('') %}
{% set cover_thumb = hero.cover_thumb|default('') %}
{% set schedule_summary = hero.schedule_summary|default('') %}
{% set display_label = hero.display_label|default('') %}
{% set weekly_schedule = hero.weekly_schedule|default({}) %}
{% set price_label = hero.price_label|default('') %}
{% set inline_schedule_html = hero.inline_schedule_html|default('') %}
{% set next_occurrence = hero.next_occurrence|default({}) %}
{% set next_occurrence_label = hero.next_occurrence_label|default('') %}
{% set photo_items = photos.items|default([]) %}
{% set photo_total = photos.total|default(photo_items|length) %}

<section class="mj-event-page__hero">
    <div class="mj-event-page__hero-content">
        <div class="mj-event-page__hero-text">
            {# Badges #}
            <div class="mj-event-page__badges">
                {% if status_label and not is_active %}
                    <span class="mj-event-page__badge mj-event-page__badge--status mj-event-page__badge--{{ status }}">{{ status_label }}</span>
                {% endif %}
            </div>

            {# Titre #}
            <h1 class="mj-event-page__title">{{ title }}</h1>

            {% if inline_schedule_html %}
                {{ inline_schedule_html|raw }}
            {% elseif schedule_summary %}
                <p class="mj-event-page__date">{{ schedule_summary }}</p>
            {% elseif display_label %}
                <p class="mj-event-page__date">{{ display_label }}</p>
            {% elseif next_occurrence_label %}
                <p class="mj-event-page__date">{{ next_occurrence_label }}</p>
            {% elseif next_occurrence.full_date %}
                {% set time_range = '' %}
                {% if next_occurrence.is_all_day|default(false) %}
                    {% set time_range = next_occurrence.all_day_label|default(__('Toute la journée', 'mj-member')) %}
                {% elseif next_occurrence.time_start %}
                    {% set time_range = next_occurrence.time_start %}
                    {% if next_occurrence.time_end and next_occurrence.time_end != next_occurrence.time_start %}
                        {% set time_range = time_range ~ ' - ' ~ next_occurrence.time_end %}
                    {% endif %}
                {% endif %}
                <p class="mj-event-page__date">
                    {{ next_occurrence_label|default('') ?: (next_occurrence.full_date ~ (time_range ? ' - ' ~ time_range : '')) }}
                </p>
            {% endif %}

            {# Tarif #}
            {% if price_label %}
                <div class="mj-event-page__price">
                    <svg class="mj-event-page__price-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
                    <span class="mj-event-page__price-text">{{ price_label }}</span>
                </div>
            {% endif %}

            {% if photo_items|length > 0 %}
                <div class="mj-event-page__hero-mini-gallery" aria-label="{{ __('Aperçu des photos de l\'événement', 'mj-member') }}">
                    {% for photo in photo_items|slice(0, 8) %}
                        {% set thumb = photo.thumb|default(photo.url|default('')) %}
                        {% set full = photo.full|default(photo.url|default('')) %}
                        {% set caption = photo.caption|default(__('Photo de l\'événement', 'mj-member')) %}
                        {% if thumb %}
                            <a class="mj-event-page__hero-mini-thumb" href="{{ full|esc_url }}" target="_blank" rel="noopener" title="{{ caption|esc_attr }}" data-mj-event-preview="1" data-mj-event-preview-group="hero" data-mj-event-preview-caption="{{ caption|esc_attr }}" data-elementor-open-lightbox="no" data-lightbox="none" data-fancybox="">
                                <img src="{{ thumb|esc_url }}" alt="{{ caption|esc_attr }}" loading="lazy" decoding="async" />
                            </a>
                        {% endif %}
                    {% endfor %}
                    {% if photo_total > 8 %}
                        <span class="mj-event-page__hero-mini-more">+{{ photo_total - 8 }}</span>
                    {% endif %}
                    {% for photo in photo_items|slice(8) %}
                        {% set full = photo.full|default(photo.url|default('')) %}
                        {% set caption = photo.caption|default(__('Photo de l\'événement', 'mj-member')) %}
                        {% if full %}
                            <a class="mj-event-page__hero-mini-hidden-link" href="{{ full|esc_url }}" data-mj-event-preview="1" data-mj-event-preview-group="hero" data-mj-event-preview-caption="{{ caption|esc_attr }}" data-elementor-open-lightbox="no" data-lightbox="none" data-fancybox="" aria-hidden="true" tabindex="-1"></a>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Image de couverture #}
        {% if cover_url %}
            <div class="mj-event-page__hero-cover">
                {% if type_label %}
                    <span class="mj-event-page__badge mj-event-page__badge--type">{{ type_label }}</span>
                {% endif %}
                <img 
                    src="{{ cover_url|esc_url }}" 
                    alt="{{ title|esc_attr }}" 
                    loading="eager"
                    decoding="async"
                />
            </div>
        {% endif %}
    </div>
</section>
