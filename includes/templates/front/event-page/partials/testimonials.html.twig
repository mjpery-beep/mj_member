{% set items = testimonials.items|default([]) %}
{% set total = testimonials.total|default(0) %}
{% set all_url = testimonials.all_url|default('') %}
{% set allow_submission = testimonials.allow_submission|default(false) %}
{% set is_logged_in = testimonials.is_logged_in|default(false) %}
{% set event_slug = testimonials.event_slug|default('') %}
{% set event_title = testimonials.event_title|default('') %}
{% set max_photos = testimonials.max_photos|default(5) %}
{% set allow_video = testimonials.allow_video|default(true) %}

<section class="mj-event-page__card mj-event-page__testimonials">
    <div class="mj-event-page__testimonials-header">
        <h2>{{ __('Vos retours d\'expérience', 'mj-member') }}</h2>
        {% if total > 0 %}
            <span class="mj-event-page__testimonials-count">
                {{ _n('%d témoignage', '%d témoignages', total, 'mj-member')|format(total) }}
            </span>
        {% endif %}
    </div>

    {# ── Submission form ── #}
    {% if allow_submission %}
        <div class="mj-testimonials mj-testimonials__form-section mj-event-page__testimonials-form-section">
            {% if is_logged_in %}
                <form class="mj-testimonials__form" data-event-slug="{{ event_slug|esc_attr }}">
                    <div class="mj-testimonials__form-content">
                        <textarea
                            name="content"
                            class="mj-testimonials__textarea"
                            placeholder="{{ __('Partagez votre expérience…', 'mj-member') }}"
                            rows="3"
                        ></textarea>
                    </div>

                    <div class="mj-testimonials__media-section">
                        <div class="mj-testimonials__photos-grid" data-photos="[]"></div>

                        <div class="mj-testimonials__media-actions">
                            <button type="button" class="mj-btn mj-btn--secondary mj-testimonials__add-photo">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                    <polyline points="21 15 16 10 5 21"></polyline>
                                </svg>
                                <span>{{ __('Photos / Vidéos', 'mj-member') }}</span>
                            </button>

                            <button type="button" class="mj-btn mj-btn--secondary mj-testimonials__capture-photo">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                                    <circle cx="12" cy="13" r="4"></circle>
                                </svg>
                                <span>{{ __('Prendre une photo', 'mj-member') }}</span>
                            </button>

                            {% if allow_video %}
                                <button type="button" class="mj-btn mj-btn--secondary mj-testimonials__add-video">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <circle cx="12" cy="12" r="3" fill="currentColor"></circle>
                                    </svg>
                                    <span>{{ __('Filmer', 'mj-member') }}</span>
                                </button>
                            {% endif %}
                        </div>

                        <div class="mj-testimonials__camera-preview" style="display: none;">
                            <video class="mj-testimonials__camera-element" playsinline></video>
                            <div class="mj-testimonials__camera-controls">
                                <button type="button" class="mj-btn mj-btn--primary mj-testimonials__camera-capture">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"></circle>
                                    </svg>
                                    <span>{{ __('Capturer', 'mj-member') }}</span>
                                </button>
                                <button type="button" class="mj-btn mj-btn--ghost mj-testimonials__camera-cancel">
                                    {{ __('Annuler', 'mj-member') }}
                                </button>
                            </div>
                        </div>

                        <div class="mj-testimonials__video-preview" style="display: none;">
                            <video class="mj-testimonials__video-element" playsinline></video>
                            <div class="mj-testimonials__video-controls">
                                <button type="button" class="mj-btn mj-btn--danger mj-testimonials__video-record">
                                    <span class="mj-testimonials__video-record-dot"></span>
                                    <span>{{ __('Enregistrer', 'mj-member') }}</span>
                                </button>
                                <button type="button" class="mj-btn mj-btn--secondary mj-testimonials__video-stop" style="display: none;">
                                    {{ __('Arrêter', 'mj-member') }}
                                </button>
                                <button type="button" class="mj-btn mj-btn--ghost mj-testimonials__video-cancel">
                                    {{ __('Annuler', 'mj-member') }}
                                </button>
                            </div>
                        </div>

                        <div class="mj-testimonials__video-result" style="display: none;">
                            <video class="mj-testimonials__video-playback" controls playsinline></video>
                            <div class="mj-testimonials__video-result-actions">
                                <button type="button" class="mj-btn mj-btn--secondary mj-testimonials__video-retake">
                                    {{ __('Recommencer', 'mj-member') }}
                                </button>
                                <button type="button" class="mj-btn mj-btn--danger mj-testimonials__video-remove">
                                    {{ __('Supprimer', 'mj-member') }}
                                </button>
                            </div>
                        </div>
                    </div>

                    <input type="file" class="mj-testimonials__photo-input" accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/quicktime" multiple style="display: none;">
                    <input type="hidden" name="photo_ids" value="[]">
                    <input type="hidden" name="video_id" value="">

                    <div class="mj-testimonials__form-footer">
                        <div class="mj-testimonials__form-status"></div>
                        <button type="submit" class="mj-btn mj-btn--primary mj-testimonials__submit">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="22" y1="2" x2="11" y2="13"></line>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                            </svg>
                            <span>{{ __('Envoyer mon témoignage', 'mj-member') }}</span>
                        </button>
                    </div>
                </form>
            {% else %}
                <div class="mj-testimonials__login-prompt">
                    <p>{{ __('Connectez-vous pour partager votre témoignage.', 'mj-member') }}</p>
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# ── Existing testimonials list ── #}
    {% if items|length > 0 %}
    <div class="mj-event-page__testimonials-list">
        {% for item in items %}
            <article class="mj-event-page__testimonial">
                <div class="mj-event-page__testimonial-author">
                    {% if item.author_avatar %}
                        <img
                            class="mj-event-page__testimonial-avatar"
                            src="{{ item.author_avatar|esc_url }}"
                            alt=""
                            loading="lazy"
                            decoding="async"
                        />
                    {% elseif item.author_initials %}
                        <span class="mj-event-page__testimonial-initials">{{ item.author_initials }}</span>
                    {% else %}
                        <span class="mj-event-page__testimonial-initials">?</span>
                    {% endif %}
                    <div class="mj-event-page__testimonial-meta">
                        <span class="mj-event-page__testimonial-name">{{ item.author_name }}</span>
                        {% if item.date_label %}
                            <time class="mj-event-page__testimonial-date" datetime="{{ item.date_iso|default('')|esc_attr }}">{{ item.date_label }}</time>
                        {% endif %}
                    </div>
                </div>

                {% if item.content %}
                    <div class="mj-event-page__testimonial-content">
                        {{ item.content|wp_kses_post }}
                    </div>
                {% endif %}

                {% if item.photos|default([])|length > 0 %}
                    <div class="mj-event-page__testimonial-photos">
                        {% for photo in item.photos %}
                            <a href="{{ photo.full|esc_url }}" target="_blank" rel="noopener" class="mj-event-page__testimonial-photo-link">
                                <img
                                    src="{{ photo.thumb|esc_url }}"
                                    alt=""
                                    loading="lazy"
                                    decoding="async"
                                />
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if item.video %}
                    <div class="mj-event-page__testimonial-video">
                        <video
                            controls
                            preload="metadata"
                            playsinline
                            {% if item.video.poster %}poster="{{ item.video.poster|esc_url }}"{% endif %}
                            class="mj-event-page__testimonial-video-player"
                        >
                            <source src="{{ item.video.url|esc_url }}" />
                        </video>
                    </div>
                {% endif %}

                {% if item.link_preview %}
                    {% set lp = item.link_preview %}
                    <a href="{{ lp.url|esc_url }}" target="_blank" rel="noopener noreferrer" class="mj-event-page__testimonial-link-preview">
                        {% if lp.image %}
                            <img class="mj-event-page__testimonial-lp-image" src="{{ lp.image|esc_url }}" alt="" loading="lazy" decoding="async" />
                        {% endif %}
                        <div class="mj-event-page__testimonial-lp-body">
                            {% if lp.site_name %}
                                <span class="mj-event-page__testimonial-lp-site">{{ lp.site_name }}</span>
                            {% endif %}
                            {% if lp.title %}
                                <span class="mj-event-page__testimonial-lp-title">{{ lp.title }}</span>
                            {% endif %}
                            {% if lp.description %}
                                <span class="mj-event-page__testimonial-lp-desc">{{ lp.description }}</span>
                            {% endif %}
                        </div>
                    </a>
                {% endif %}
            </article>
        {% endfor %}
    </div>

    {% if all_url %}
        <div class="mj-event-page__testimonials-footer">
            <a href="{{ all_url|esc_url }}" class="mj-event-page__testimonials-all">
                {{ __('Voir tous les témoignages', 'mj-member') }}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
            </a>
        </div>
    {% endif %}
    {% endif %}
</section>
